{
  "_comment": "NetSentry v0.1.0 example rules. Copy to configs/rules.json or edit in place for local development.",
  "rules": [
    {
      "id": "rule-001",
      "name": "SQL Injection - Union Select",
      "type": "payload_match",
      "enabled": true,
      "severity": "high",
      "priority": 800,
      "early_exit": false,
      "config": {
        "keywords": [
          "union select",
          "union all select",
          "' or '1'='1",
          "'; drop table",
          "--"
        ],
        "case_insensitive": true,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          8443
        ],
        "direction": "dest",
        "depth": 4096,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Initial Access",
          "technique_id": "T1190",
          "technique_name": "Exploit Public-Facing Application"
        }
      ],
      "description": "Detect common SQL injection strings in cleartext payloads."
    },
    {
      "id": "rule-002",
      "name": "XSS - Script Injection",
      "type": "payload_match",
      "enabled": true,
      "severity": "medium",
      "priority": 600,
      "early_exit": false,
      "config": {
        "keywords": [
          "<script>",
          "javascript:",
          "onerror=",
          "onload=",
          "alert("
        ],
        "case_insensitive": true,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          8443
        ],
        "direction": "dest",
        "depth": 4096,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Initial Access",
          "technique_id": "T1190",
          "technique_name": "Exploit Public-Facing Application"
        }
      ],
      "description": "Detect common reflected/script injection strings."
    },
    {
      "id": "rule-003",
      "name": "Path Traversal",
      "type": "payload_match",
      "enabled": true,
      "severity": "high",
      "priority": 700,
      "early_exit": false,
      "config": {
        "keywords": [
          "../../../",
          "..\\..\\..\\",
          "%2e%2e%2f",
          "%2e%2e/"
        ],
        "case_insensitive": true,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          8443
        ],
        "direction": "dest",
        "depth": 4096,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Initial Access",
          "technique_id": "T1190",
          "technique_name": "Exploit Public-Facing Application"
        }
      ],
      "description": "Detect path traversal indicators."
    },
    {
      "id": "rule-004",
      "name": "Shell Command Injection",
      "type": "payload_match",
      "enabled": true,
      "severity": "critical",
      "priority": 900,
      "early_exit": false,
      "config": {
        "keywords": [
          ";id;",
          ";whoami;",
          "|id|",
          "|whoami|",
          "$(id)",
          "`id`",
          "bash -i",
          "sh -i"
        ],
        "case_insensitive": true,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          8443,
          4444
        ],
        "direction": "dest",
        "depth": 4096,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Execution",
          "technique_id": "T1059.004",
          "technique_name": "Command and Scripting Interpreter: Unix Shell"
        }
      ],
      "description": "Detect common command execution markers."
    },
    {
      "id": "rule-005",
      "name": "Log4Shell (CVE-2021-44228)",
      "type": "payload_match",
      "enabled": true,
      "severity": "critical",
      "priority": 1000,
      "early_exit": false,
      "config": {
        "keywords": [
          "${jndi:ldap://",
          "${jndi:rmi://",
          "${jndi:dns://",
          "${${lower:j}ndi:"
        ],
        "case_insensitive": false,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          8443,
          9200
        ],
        "direction": "dest",
        "depth": 4096,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Initial Access",
          "technique_id": "T1190",
          "technique_name": "Exploit Public-Facing Application"
        }
      ],
      "description": "Detect Log4Shell JNDI lookup patterns."
    },
    {
      "id": "rule-006",
      "name": "Known C2 IP Blacklist",
      "type": "ip_blacklist",
      "enabled": true,
      "severity": "critical",
      "priority": 1000,
      "early_exit": true,
      "config": {
        "ips": [
          "198.51.100.0/24",
          "203.0.113.0/24",
          "192.0.2.0/24"
        ],
        "direction": "any"
      },
      "mitre_techniques": [
        {
          "tactic": "Command and Control",
          "technique_id": "T1071",
          "technique_name": "Application Layer Protocol"
        }
      ],
      "description": "Detect known malicious infrastructure ranges from documentation examples."
    },
    {
      "id": "rule-007",
      "name": "Scanner User-Agent Strings",
      "type": "payload_match",
      "enabled": true,
      "severity": "low",
      "priority": 200,
      "early_exit": false,
      "config": {
        "keywords": [
          "nmap scripting engine",
          "masscan",
          "zgrab",
          "sqlmap",
          "nikto",
          "dirbuster"
        ],
        "case_insensitive": true,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          8443
        ],
        "direction": "dest",
        "depth": 2048,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Reconnaissance",
          "technique_id": "T1595",
          "technique_name": "Active Scanning"
        }
      ],
      "description": "Detect common scanner user-agent markers."
    },
    {
      "id": "rule-008",
      "name": "Reverse Shell Indicators",
      "type": "payload_match",
      "enabled": true,
      "severity": "critical",
      "priority": 950,
      "early_exit": false,
      "config": {
        "keywords": [
          "bash -i >& /dev/tcp/",
          "0>&1",
          "exec /bin/sh",
          "python -c 'import socket",
          "nc -e /bin/sh"
        ],
        "case_insensitive": false,
        "protocols": [
          "TCP"
        ],
        "ports": [
          80,
          8080,
          443,
          4444
        ],
        "direction": "dest",
        "depth": 4096,
        "offset": 0
      },
      "mitre_techniques": [
        {
          "tactic": "Execution",
          "technique_id": "T1059.004",
          "technique_name": "Command and Scripting Interpreter: Unix Shell"
        }
      ],
      "description": "Detect common reverse shell payload fragments."
    }
  ]
}
