[
  {
    "id": "rule-001",
    "name": "SQL Injection - Union Select",
    "type": "payload_match",
    "enabled": true,
    "severity": "high",
    "priority": 800,
    "early_exit": false,
    "mitre_tactic": "Initial Access",
    "mitre_technique_id": "T1190",
    "mitre_technique_name": "Exploit Public-Facing Application",
    "payload_match": {
      "keywords": ["union select", "union all select", "' or '1'='1", "'; drop table", "--"],
      "case_insensitive": true
    }
  },
  {
    "id": "rule-002",
    "name": "XSS - Script Injection",
    "type": "payload_match",
    "enabled": true,
    "severity": "medium",
    "priority": 600,
    "early_exit": false,
    "mitre_tactic": "Initial Access",
    "mitre_technique_id": "T1190",
    "mitre_technique_name": "Exploit Public-Facing Application",
    "payload_match": {
      "keywords": ["<script>", "javascript:", "onerror=", "onload=", "alert("],
      "case_insensitive": true
    }
  },
  {
    "id": "rule-003",
    "name": "Path Traversal",
    "type": "payload_match",
    "enabled": true,
    "severity": "high",
    "priority": 700,
    "early_exit": false,
    "mitre_tactic": "Discovery",
    "mitre_technique_id": "T1083",
    "mitre_technique_name": "File and Directory Discovery",
    "payload_match": {
      "keywords": ["../../../", "..\\..\\..\\", "%2e%2e%2f", "%2e%2e/"],
      "case_insensitive": true
    }
  },
  {
    "id": "rule-004",
    "name": "Shell Command Injection",
    "type": "payload_match",
    "enabled": true,
    "severity": "critical",
    "priority": 900,
    "early_exit": false,
    "mitre_tactic": "Execution",
    "mitre_technique_id": "T1059",
    "mitre_technique_name": "Command and Scripting Interpreter",
    "payload_match": {
      "keywords": [";id;", ";whoami;", "|id|", "|whoami|", "$(id)", "`id`", "bash -i", "sh -i"],
      "case_insensitive": true
    }
  },
  {
    "id": "rule-005",
    "name": "Log4Shell (CVE-2021-44228)",
    "type": "payload_match",
    "enabled": true,
    "severity": "critical",
    "priority": 1000,
    "early_exit": false,
    "mitre_tactic": "Initial Access",
    "mitre_technique_id": "T1190",
    "mitre_technique_name": "Exploit Public-Facing Application",
    "payload_match": {
      "keywords": ["${jndi:ldap://", "${jndi:rmi://", "${jndi:dns://", "${${lower:j}ndi:"],
