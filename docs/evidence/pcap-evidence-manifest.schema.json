{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/decline-llc/netsentry/docs/evidence/pcap-evidence-manifest.schema.json",
  "title": "NetSentry Production-Derived PCAP Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_utc",
    "evidence_class",
    "path_redacted",
    "file_count",
    "packet_count",
    "artifacts",
    "provenance",
    "sanitization",
    "sensitive_metadata_handling",
    "reviews",
    "review_status"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generated_utc": {"type": "string", "format": "date-time"},
    "evidence_class": {"const": "production-derived"},
    "path_redacted": {"const": true},
    "file_count": {"type": "integer", "minimum": 1},
    "packet_count": {"type": "integer", "minimum": 1},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "bytes", "packet_count", "sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "bytes": {"type": "integer", "minimum": 1},
          "packet_count": {"type": "integer", "minimum": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "provenance": {"type": "object"},
    "sanitization": {"type": "object"},
    "sensitive_metadata_handling": {"type": "object"},
    "reviews": {"type": "object"},
    "review_status": {"enum": ["pending", "approved", "rejected"]},
    "approval": {"type": ["object", "null"]}
  }
}
